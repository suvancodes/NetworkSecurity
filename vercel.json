{
  "version": 2,
  "builds": [{ "src": "static_site/**", "use": "@vercel/static" }],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static_site/static/$1" },

    { "src": "/scan", "dest": "https://networksecurity-s6xe.onrender.com/scan" },
    { "src": "/predict", "dest": "https://networksecurity-s6xe.onrender.com/predict" },
    { "src": "/threat-analysis", "dest": "https://networksecurity-s6xe.onrender.com/threat-analysis" },

    { "src": "/", "dest": "/static_site/index.html" },
    { "src": "/(.*)", "dest": "/static_site/$1" }
  ]
}